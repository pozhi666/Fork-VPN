# Copy to .env and fill in. NEVER commit real values.
NODE_ENV=development
FORK_BIND=127.0.0.1
FORK_PORT=8787
FORK_PUBLIC_URL=http://127.0.0.1:8787
FORK_CORS_ORIGINS=http://127.0.0.1:8787,http://localhost:1420,http://localhost:3000
FORK_JWT_SECRET=dev-only-change-me-to-32chars-min!!
FORK_JWT_EXPIRES=7d
# Production: omit FORK_TEST_INSECURE_HTTP; use HTTPS public URL

# Optional: 易支付
# EZPAY_URL=https://pay.example.com
# EZPAY_PID=
# EZPAY_KEY=

# Optional: Postgres
# DATABASE_URL=postgres://user:pass@127.0.0.1:5432/fork

# 生产首次建管理员时使用，成功后删除
# FORK_BOOTSTRAP_TOKEN=
